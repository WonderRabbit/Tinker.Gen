{
  "name": "tinker-gen",
  "version": "0.1.0",
  "description": "Deterministic architecture analysis and safe code generation scaffold CLI.",
  "type": "module",
  "bin": {
    "tinker": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "rm -rf dist-test && vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "ignore": "^7.0.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@types/node": "^24.10.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
