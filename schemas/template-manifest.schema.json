{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonderrabbit.dev/tinker/template-manifest.schema.json",
  "title": "Tinker template manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "template", "language", "layers", "component", "output"],
  "properties": {
    "schemaVersion": { "const": "tinker.template-manifest.v1" },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "const": "component-scaffold" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "language": { "const": "typescript" },
    "layers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "exportName", "description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "exportName": { "type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root"],
      "properties": {
        "root": { "type": "string", "minLength": 1 }
      }
    }
  }
}
